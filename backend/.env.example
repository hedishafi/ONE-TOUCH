SECRET_KEY=change-me-in-production
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0

DB_NAME=onetouch
DB_USER=onetouch
DB_PASSWORD=onetouch
DB_HOST=db
DB_PORT=5432

REDIS_URL=redis://redis:6379/0

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@onetouch.et
DJANGO_SUPERUSER_PASSWORD=admin1234

# Chapa payment gateway (get from dashboard.chapa.co)
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=

# AI / Transcription (optional — fill when implementing AI phase)
OPENAI_API_KEY=

# OCR engine configuration:
# - tesseract (default, local/free)
# - google (higher accuracy, requires Google service-account key)
OCR_ENGINE=tesseract

# Path inside container to Google Vision credentials JSON.
# If OCR_ENGINE=google, place key file at backend/.secrets/google-vision.json
GOOGLE_APPLICATION_CREDENTIALS=/home/appuser/code/.secrets/google-vision.json
